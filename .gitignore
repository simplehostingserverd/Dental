# Security & Privacy - DO NOT COMMIT
# Cookie files from testing
cookies*.txt
*.cookies
/cookies/

# Session files
sessions/
*.session

# Private keys and certificates
*.key
*.crt
*.p12
*.pfx

# Backup files
*.backup
*.bak
*.tmp

# Log files with potentially sensitive data
*.log
logs/
/var/log/

# Configuration files that might contain secrets
config.local.*
.env.production
.env.staging
.env.coolify

# Environment variables files with sensitive data
COOLIFY_ENV_VARIABLES.txt
PRODUCTION_ENV_VARIABLES.txt

# Deployment guides with sensitive information
COOLIFY_DEPLOYMENT.md
CPANEL_DEPLOYMENT_GUIDE.md
DEPLOYMENT_GUIDE.md
DEPLOYMENT_README.md
MULTI_TENANT_SAAS_GUIDE.md

# Test data with credentials
TEST_USERS.md

# Scripts with sensitive data
generate-secrets.sh
init.sql
install.sh

# Database dumps and exports
*.sql
*.dump
*.backup

# User uploads (might contain sensitive patient data)
/uploads/
/public/uploads/
/storage/

# Cache files that might contain sensitive data
.cache/
*.cache

# IDE and editor files that might contain sensitive info
.vscode/settings.json
.vscode/launch.json
*.swp
*.swo
*~

# OS generated files
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

