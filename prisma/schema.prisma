generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Practice Management Models
model Practice {
  id           String         @id @default(cuid())
  name         String
  phone        String?
  email        String?
  address      String?
  city         String?
  state        String?
  zipCode      String?
  website      String?
  timezone     String         @default("America/New_York")
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  // Relations
  practiceUsers PracticeUser[]
  patients      Patient[]
  auditLogs     AuditLog[]
  settings      PracticeSettings?
}

model PracticeUser {
  id                String    @id @default(cuid())
  email             String    @unique
  password          String?
  firstName         String
  lastName          String
  role              PracticeRole
  practiceId        String
  phone             String?
  licenseNumber     String?
  specialization    String?
  isActive          Boolean   @default(true)
  emailVerified     Boolean   @default(false)
  lastLoginAt       DateTime?
  lastLogin         DateTime? // Alias for compatibility
  loginAttempts     Int       @default(0)
  lockedUntil       DateTime?
  twoFactorEnabled  Boolean   @default(false)
  twoFactorSecret   String?
  backupCodes       String[]
  resetToken        String?
  resetTokenExpiry  DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  practice          Practice  @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  appointments      Appointment[]
  messagesSent      Message[] @relation("SentMessages")
  tasks             Task[]    @relation("AssignedTasks")
  auditLogs         AuditLog[]
}

model PatientUser {
  id                String    @id @default(cuid())
  email             String    @unique
  password          String
  isActive          Boolean   @default(true)
  lastLoginAt       DateTime?
  lastLogin         DateTime? // Alias for compatibility
  loginAttempts     Int       @default(0)
  lockedUntil       DateTime?
  twoFactorEnabled  Boolean   @default(false)
  twoFactorSecret   String?
  backupCodes       String[]
  resetToken        String?
  resetTokenExpiry  DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  patient           Patient?
}

model PracticeSettings {
  id                    String   @id @default(cuid())
  practiceId            String   @unique
  appointmentDuration   Int      @default(30) // minutes
  workingHoursStart     String   @default("09:00")
  workingHoursEnd       String   @default("17:00")
  workingDays           String[] @default(["MONDAY", "TUESDAY", "WEDNESDAY", "THURSDAY", "FRIDAY"])
  timeZone              String   @default("America/New_York")
  emailNotifications    Boolean  @default(true)
  smsNotifications      Boolean  @default(false)
  reminderHours         Int      @default(24)
  allowOnlineBooking    Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  practice              Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  entityType  String
  entityId    String
  resource    String?  // Additional resource field
  userId      String
  practiceId  String
  ipAddress   String?
  userAgent   String?
  details     Json?
  createdAt   DateTime @default(now())

  // Relations
  practice    Practice     @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  user        PracticeUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([practiceId, createdAt])
  @@index([userId, createdAt])
}

// Legacy NextAuth models (kept for compatibility)
model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String?
  access_token             String?
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?
  session_state            String?
  refresh_token_expires_in Int?
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Legacy User model (kept for NextAuth compatibility)
model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?       @unique
  emailVerified DateTime?
  image         String?
  role          Role          @default(STAFF)
  password      String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  accounts      Account[]
  sessions      Session[]
  posts         Post[]
}

model Post {
  id          Int      @id @default(autoincrement())
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])

  @@index([name])
}

model Patient {
  id            String         @id @default(cuid())
  firstName     String
  lastName      String
  dateOfBirth   DateTime
  gender        String
  phone         String?
  email         String?
  address       String?
  city          String?
  state         String?
  zipCode       String?
  emergencyContact String?
  emergencyPhone   String?
  insurance     String?        // General insurance field
  insuranceProvider String?
  insurancePolicyNumber String?
  practiceId    String
  patientUserId String?        @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // Relations
  practice      Practice       @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  patientUser   PatientUser?   @relation(fields: [patientUserId], references: [id])
  appointments  Appointment[]
  invoices      Invoice[]
  messages      Message[]      @relation("PatientMessages")
  notes         Note[]
  prescriptions Prescription[]
  referrals     Referral[]
  reminders     Reminder[]
  treatments    Treatment[]
  xrays         Xray[]
}

model Appointment {
  id              String            @id @default(cuid())
  start           DateTime
  end             DateTime
  status          AppointmentStatus @default(SCHEDULED)
  notes           String?
  appointmentType String?
  patientId       String
  practiceUserId  String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Relations
  patient         Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  practiceUser    PracticeUser      @relation(fields: [practiceUserId], references: [id], onDelete: Cascade)
}

model Treatment {
  id          String   @id @default(cuid())
  title       String
  description String
  cost        Float
  date        DateTime @default(now())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id])
}

model Invoice {
  id        String        @id @default(cuid())
  total     Float
  paid      Boolean       @default(false)
  dueDate   DateTime
  status    InvoiceStatus
  patientId String
  patient   Patient       @relation(fields: [patientId], references: [id])
}

model Message {
  id        String       @id @default(cuid())
  content   String
  timestamp DateTime     @default(now())
  senderId  String
  patientId String
  isRead    Boolean      @default(false)

  // Relations
  patient   Patient      @relation("PatientMessages", fields: [patientId], references: [id], onDelete: Cascade)
  sender    PracticeUser @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
}

model Reminder {
  id        String       @id @default(cuid())
  type      ReminderType
  scheduled DateTime
  sent      Boolean      @default(false)
  patientId String
  patient   Patient      @relation(fields: [patientId], references: [id])
}

model Xray {
  id        String   @id @default(cuid())
  imageUrl  String
  takenAt   DateTime @default(now())
  notes     String?
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id])
}

model Task {
  id           String       @id @default(cuid())
  title        String
  description  String?
  done         Boolean      @default(false)
  priority     TaskPriority @default(MEDIUM)
  dueDate      DateTime?
  assignedToId String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Relations
  assignedTo   PracticeUser @relation("AssignedTasks", fields: [assignedToId], references: [id], onDelete: Cascade)
}

model Referral {
  id         String  @id @default(cuid())
  referredBy String
  notes      String?
  patientId  String
  patient    Patient @relation(fields: [patientId], references: [id])
}

model Prescription {
  id        String   @id @default(cuid())
  drugName  String
  dosage    String
  issuedAt  DateTime @default(now())
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id])
}

model Note {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id])
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELED
  NO_SHOW
  RESCHEDULED
}

enum InvoiceStatus {
  UNPAID
  PAID
  PARTIAL
  OVERDUE
  CANCELED
}

enum ReminderType {
  EMAIL
  SMS
  IN_APP
  PHONE
}

enum PracticeRole {
  ADMIN
  DOCTOR
  HYGIENIST
  ASSISTANT
  RECEPTIONIST
  MANAGER
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// Legacy enum for NextAuth compatibility
enum Role {
  ADMIN
  DOCTOR
  STAFF
}
