generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Practice Management Models
model Practice {
  id           String         @id @default(cuid())
  name         String
  phone        String?
  email        String?
  address      String?
  city         String?
  state        String?
  zipCode      String?
  website      String?
  timezone     String         @default("America/New_York")
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  // Relations
  practiceUsers PracticeUser[]
  patients      Patient[]
  auditLogs     AuditLog[]
  settings      PracticeSettings?

  // New relations for receptionist features
  payments              Payment[]
  insuranceClaims       InsuranceClaim[]
  documents             Document[]
  formTemplates         FormTemplate[]
  forms                 Form[]
  communicationTemplates CommunicationTemplate[]
  communicationLogs     CommunicationLog[]
  workflowTemplates     WorkflowTemplate[]
  workflowInstances     WorkflowInstance[]
  analyticsEvents       AnalyticsEvent[]
  reports               Report[]
  socialMediaAccounts   SocialMediaAccount[]
  socialPosts           SocialPost[]
  marketingCampaigns    MarketingCampaign[]
  automationRules       AutomationRule[]
  integrationSettings   IntegrationSettings[]
  communicationSettings CommunicationSettings?

  // Billing & Insurance Relations
  insurancePayers       InsurancePayer[]
  clearinghouses        Clearinghouse[]
  eligibilityChecks     EligibilityCheck[]
  claims                Claim[]
  ledgerEntries         LedgerEntry[]
  accountsReceivable    AccountsReceivable[]
  patientInvoices       PatientInvoice[]
  financingOptions      FinancingOption[]
  patientFinancing      PatientFinancing[]
  paymentPlans          PaymentPlan[]
}

model PracticeUser {
  id                String    @id @default(cuid())
  stackUserId       String?   @unique // Stack Auth user ID
  email             String    @unique
  password          String?
  firstName         String
  lastName          String
  role              PracticeRole
  practiceId        String
  phone             String?
  licenseNumber     String?
  specialization    String?
  isActive          Boolean   @default(true)
  emailVerified     Boolean   @default(false)
  lastLoginAt       DateTime?
  lastLogin         DateTime? // Alias for compatibility
  loginAttempts     Int       @default(0)
  lockedUntil       DateTime?
  twoFactorEnabled  Boolean   @default(false)
  twoFactorSecret   String?
  backupCodes       String[]
  resetToken        String?
  resetTokenExpiry  DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  practice          Practice  @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  appointments      Appointment[]
  messagesSent      Message[] @relation("SentMessages")
  tasks             Task[]    @relation("AssignedTasks")
  auditLogs         AuditLog[]

  // New relations for receptionist features
  documentsUploaded    Document[]
  communicationsSent   CommunicationLog[]
  workflowsTriggered   WorkflowInstance[]
  analyticsEvents      AnalyticsEvent[]
  reportsGenerated     Report[]
  socialPostsCreated   SocialPost[]
  campaignsCreated     MarketingCampaign[]
}

model PatientUser {
  id                String    @id @default(cuid())
  stackUserId       String?   @unique // Stack Auth user ID
  email             String    @unique
  password          String
  isActive          Boolean   @default(true)
  lastLoginAt       DateTime?
  lastLogin         DateTime? // Alias for compatibility
  loginAttempts     Int       @default(0)
  lockedUntil       DateTime?
  twoFactorEnabled  Boolean   @default(false)
  twoFactorSecret   String?
  backupCodes       String[]
  resetToken        String?
  resetTokenExpiry  DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  patient           Patient?
}

model PracticeSettings {
  id                    String   @id @default(cuid())
  practiceId            String   @unique
  appointmentDuration   Int      @default(30) // minutes
  workingHoursStart     String   @default("09:00")
  workingHoursEnd       String   @default("17:00")
  workingDays           String[] @default(["MONDAY", "TUESDAY", "WEDNESDAY", "THURSDAY", "FRIDAY"])
  timeZone              String   @default("America/New_York")
  emailNotifications    Boolean  @default(true)
  smsNotifications      Boolean  @default(false)
  reminderHours         Int      @default(24)
  allowOnlineBooking    Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  practice              Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  entityType  String
  entityId    String
  resource    String?  // Additional resource field
  userId      String
  practiceId  String
  ipAddress   String?
  userAgent   String?
  details     Json?
  createdAt   DateTime @default(now())

  // Relations
  practice    Practice     @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  user        PracticeUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([practiceId, createdAt])
  @@index([userId, createdAt])
}

// Legacy NextAuth models (kept for compatibility)
model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String?
  access_token             String?
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?
  session_state            String?
  refresh_token_expires_in Int?
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Legacy User model (kept for NextAuth compatibility)
model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?       @unique
  emailVerified DateTime?
  image         String?
  role          Role          @default(STAFF)
  password      String?
  hashedPassword String?
  salt          String?
  profile       Json?
  cryptoKeys    Json?
  lastLogin     DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  accounts      Account[]
  sessions      Session[]
  posts         Post[]
  callLogs      CallLog[]
  smsLogs       SmsLog[]
}

model Post {
  id          Int      @id @default(autoincrement())
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])

  @@index([name])
}

model Patient {
  id            String         @id @default(cuid())
  firstName     String
  lastName      String
  dateOfBirth   DateTime
  gender        String?
  phone         String?
  email         String?
  address       Json?          // JSON object for structured address
  emergencyContact Json?       // JSON object for emergency contact
  insurance     Json?          // JSON object for insurance details
  medicalHistory Json?         // JSON object for medical history
  lastVisit     DateTime?
  nextAppointment DateTime?
  totalVisits   Int            @default(0)
  outstandingBalance Float      @default(0)
  practiceId    String?
  patientUserId String?        @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // Relations
  practice      Practice?      @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  patientUser   PatientUser?   @relation(fields: [patientUserId], references: [id])
  appointments  Appointment[]
  invoices      Invoice[]
  messages      Message[]      @relation("PatientMessages")
  notes         Note[]
  prescriptions Prescription[]
  referrals     Referral[]
  reminders     Reminder[]
  treatments    Treatment[]
  xrays         Xray[]

  // New relations for receptionist features
  payments           Payment[]
  insuranceClaims    InsuranceClaim[]
  documents          Document[]
  forms              Form[]
  communicationLogs  CommunicationLog[]
  analyticsEvents    AnalyticsEvent[]
  workflowInstances  WorkflowInstance[]
  callLogs           CallLog[]
  smsLogs            SmsLog[]

  // Billing & Insurance Relations
  patientInsurances  PatientInsurance[]
  eligibilityChecks  EligibilityCheck[]
  claims             Claim[]
  ledgerEntries      LedgerEntry[]
  accountsReceivable AccountsReceivable[]
  patientInvoices    PatientInvoice[]
  patientFinancing   PatientFinancing[]
  paymentPlans       PaymentPlan[]
}

model Appointment {
  id              String            @id @default(cuid())
  patientId       String
  patientName     String
  dentistId       String
  dentistName     String
  date            DateTime
  time            String
  duration        Int               // minutes
  type            String
  status          AppointmentStatus @default(SCHEDULED)
  notes           String?
  treatmentPlan   Json?             // JSON array of treatment steps
  estimatedCost   Float?
  start           DateTime?         // Legacy field for compatibility
  end             DateTime?         // Legacy field for compatibility
  appointmentType String?           // Legacy field for compatibility
  practiceUserId  String?           // Legacy field for compatibility
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Relations
  patient         Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  practiceUser    PracticeUser?     @relation(fields: [practiceUserId], references: [id], onDelete: Cascade)
  insuranceClaims InsuranceClaim[]
  reminders       AppointmentReminder[]
}

model Treatment {
  id          String   @id @default(cuid())
  patientId   String
  dentistId   String
  date        DateTime
  procedure   String
  tooth       String?
  cost        Float
  status      TreatmentStatus @default(PLANNED)
  notes       String?
  followUpRequired Boolean @default(false)
  followUpDate DateTime?
  title       String?  // Legacy field for compatibility
  description String?  // Legacy field for compatibility
  patient     Patient  @relation(fields: [patientId], references: [id])
}

model Invoice {
  id        String        @id @default(cuid())
  patientId String
  date      DateTime
  dueDate   DateTime
  amount    Float
  paid      Float         @default(0)
  status    InvoiceStatus
  treatments Json?        // JSON array of treatment IDs
  insuranceClaim Json?    // JSON object for insurance claim details
  total     Float?        // Legacy field for compatibility
  patient   Patient       @relation(fields: [patientId], references: [id])
  payments  Payment[]
}

model Message {
  id        String       @id @default(cuid())
  content   String
  timestamp DateTime     @default(now())
  senderId  String
  patientId String
  isRead    Boolean      @default(false)

  // Relations
  patient   Patient      @relation("PatientMessages", fields: [patientId], references: [id], onDelete: Cascade)
  sender    PracticeUser @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
}

model Reminder {
  id        String       @id @default(cuid())
  type      ReminderType
  scheduled DateTime
  sent      Boolean      @default(false)
  patientId String
  patient   Patient      @relation(fields: [patientId], references: [id])
}

model Xray {
  id        String   @id @default(cuid())
  imageUrl  String
  takenAt   DateTime @default(now())
  notes     String?
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id])
}

model Task {
  id           String       @id @default(cuid())
  title        String
  description  String?
  done         Boolean      @default(false)
  priority     TaskPriority @default(MEDIUM)
  dueDate      DateTime?
  assignedToId String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Relations
  assignedTo   PracticeUser @relation("AssignedTasks", fields: [assignedToId], references: [id], onDelete: Cascade)
}

model Referral {
  id         String  @id @default(cuid())
  referredBy String
  notes      String?
  patientId  String
  patient    Patient @relation(fields: [patientId], references: [id])
}

model Prescription {
  id        String   @id @default(cuid())
  drugName  String
  dosage    String
  issuedAt  DateTime @default(now())
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id])
}

model Note {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id])
}

// Billing and Payments
model Payment {
  id            String        @id @default(cuid())
  amount        Float
  paymentMethod PaymentMethod
  status        PaymentStatus @default(PENDING)
  transactionId String?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  patientId     String
  invoiceId     String?
  practiceId    String

  // Relations
  patient  Patient  @relation(fields: [patientId], references: [id])
  invoice  Invoice? @relation(fields: [invoiceId], references: [id])
  practice Practice @relation(fields: [practiceId], references: [id])
}

model InsuranceClaim {
  id              String      @id @default(cuid())
  claimNumber     String      @unique
  amount          Float
  status          ClaimStatus @default(SUBMITTED)
  submittedAt     DateTime    @default(now())
  processedAt     DateTime?
  deniedReason    String?
  notes           String?
  patientId       String
  appointmentId   String?
  practiceId      String

  // Relations
  patient     Patient      @relation(fields: [patientId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])
  practice    Practice     @relation(fields: [practiceId], references: [id])
}

// Documents and Forms
model Document {
  id          String       @id @default(cuid())
  name        String
  type        DocumentType
  fileUrl     String
  fileSize    Int?
  mimeType    String?
  uploadedAt  DateTime     @default(now())
  expiresAt   DateTime?
  isRequired  Boolean      @default(false)
  isSigned    Boolean      @default(false)
  signedAt    DateTime?
  patientId   String?
  practiceId  String
  uploadedById String

  // Relations
  patient    Patient?     @relation(fields: [patientId], references: [id])
  practice   Practice     @relation(fields: [practiceId], references: [id])
  uploadedBy PracticeUser @relation(fields: [uploadedById], references: [id])
}

model FormTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  fields      Json     // JSON structure for form fields
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  practiceId  String

  // Relations
  practice Practice @relation(fields: [practiceId], references: [id])
  forms    Form[]
}

model Form {
  id           String       @id @default(cuid())
  data         Json         // JSON data with form responses
  status       FormStatus   @default(PENDING)
  submittedAt  DateTime?
  completedAt  DateTime?
  patientId    String?
  templateId   String
  practiceId   String

  // Relations
  patient  Patient?     @relation(fields: [patientId], references: [id])
  template FormTemplate @relation(fields: [templateId], references: [id])
  practice Practice     @relation(fields: [practiceId], references: [id])
}

// Communication and Templates
model CommunicationTemplate {
  id          String            @id @default(cuid())
  name        String
  type        TemplateType
  channel     CommunicationChannel
  subject     String?
  content     String
  variables   Json?             // JSON array of available variables
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  practiceId  String

  // Relations
  practice Practice @relation(fields: [practiceId], references: [id])
  messages CommunicationLog[]
}

model CommunicationLog {
  id          String               @id @default(cuid())
  channel     CommunicationChannel
  direction   MessageDirection
  content     String
  status      MessageStatus        @default(PENDING)
  sentAt      DateTime?
  deliveredAt DateTime?
  readAt      DateTime?
  response    String?
  templateId  String?
  patientId   String
  sentById    String
  practiceId  String

  // Relations
  patient  Patient                @relation(fields: [patientId], references: [id])
  sentBy   PracticeUser           @relation(fields: [sentById], references: [id])
  practice Practice               @relation(fields: [practiceId], references: [id])
  template CommunicationTemplate? @relation(fields: [templateId], references: [id])
}

// Tasks and Workflows
model WorkflowTemplate {
  id          String    @id @default(cuid())
  name        String
  description String?
  steps       Json      // JSON array of workflow steps
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  practiceId  String

  // Relations
  practice  Practice           @relation(fields: [practiceId], references: [id])
  instances WorkflowInstance[]
}

model WorkflowInstance {
  id           String         @id @default(cuid())
  status       WorkflowStatus @default(PENDING)
  currentStep  Int            @default(0)
  data         Json?          // JSON data for workflow context
  startedAt    DateTime       @default(now())
  completedAt  DateTime?
  templateId   String
  triggeredById String?
  patientId    String?
  practiceId   String

  // Relations
  template    WorkflowTemplate @relation(fields: [templateId], references: [id])
  triggeredBy PracticeUser?    @relation(fields: [triggeredById], references: [id])
  patient     Patient?         @relation(fields: [patientId], references: [id])
  practice    Practice         @relation(fields: [practiceId], references: [id])
  steps       WorkflowStep[]
}

model WorkflowStep {
  id           String           @id @default(cuid())
  stepNumber   Int
  name         String
  type         WorkflowStepType
  config       Json             // JSON configuration for the step
  status       StepStatus       @default(PENDING)
  executedAt   DateTime?
  completedAt  DateTime?
  error        String?
  instanceId   String

  // Relations
  instance WorkflowInstance @relation(fields: [instanceId], references: [id])
}

// Analytics and Reporting
model AnalyticsEvent {
  id         String    @id @default(cuid())
  eventType  String
  eventData  Json
  timestamp  DateTime  @default(now())
  userId     String?
  patientId  String?
  practiceId String

  // Relations
  user     PracticeUser? @relation(fields: [userId], references: [id])
  patient  Patient?      @relation(fields: [patientId], references: [id])
  practice Practice      @relation(fields: [practiceId], references: [id])
}

model Report {
  id          String     @id @default(cuid())
  name        String
  type        ReportType
  parameters  Json?      // JSON parameters for report generation
  data        Json?      // JSON report data
  generatedAt DateTime   @default(now())
  generatedBy String
  practiceId  String

  // Relations
  generator PracticeUser @relation(fields: [generatedBy], references: [id])
  practice  Practice     @relation(fields: [practiceId], references: [id])
}

// Social Media Marketing
model SocialMediaAccount {
  id          String            @id @default(cuid())
  platform    SocialPlatform
  accountName String
  accessToken String?           // Encrypted access token
  isActive    Boolean           @default(true)
  lastSync    DateTime?
  practiceId  String

  // Relations
  practice Practice     @relation(fields: [practiceId], references: [id])
  posts    SocialPost[]
}

model SocialPost {
  id          String         @id @default(cuid())
  content     String
  imageUrls   Json?          // JSON array of image URLs
  status      PostStatus     @default(DRAFT)
  scheduledAt DateTime?
  publishedAt DateTime?
  engagement  Json?          // JSON object with likes, shares, comments
  accountId   String
  createdById String
  practiceId  String

  // Relations
  account   SocialMediaAccount @relation(fields: [accountId], references: [id])
  createdBy PracticeUser       @relation(fields: [createdById], references: [id])
  practice  Practice           @relation(fields: [practiceId], references: [id])
}

model MarketingCampaign {
  id          String         @id @default(cuid())
  name        String
  type        CampaignType
  status      CampaignStatus @default(DRAFT)
  startDate   DateTime?
  endDate     DateTime?
  budget      Float?
  spent       Float          @default(0)
  metrics     Json?          // JSON object with campaign metrics
  config      Json           // JSON configuration for campaign
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  createdById String
  practiceId  String

  // Relations
  createdBy PracticeUser @relation(fields: [createdById], references: [id])
  practice  Practice     @relation(fields: [practiceId], references: [id])
}

// Automation and Triggers
model AutomationRule {
  id          String           @id @default(cuid())
  name        String
  description String?
  trigger     Json             // JSON trigger configuration
  actions     Json             // JSON array of actions
  isActive    Boolean          @default(true)
  lastRun     DateTime?
  runCount    Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  practiceId  String

  // Relations
  practice   Practice            @relation(fields: [practiceId], references: [id])
  executions AutomationExecution[]
}

model AutomationExecution {
  id          String            @id @default(cuid())
  status      ExecutionStatus   @default(RUNNING)
  startedAt   DateTime          @default(now())
  completedAt DateTime?
  error       String?
  logs        Json?             // JSON array of execution logs
  ruleId      String
  triggeredBy String?           // What triggered this execution

  // Relations
  rule AutomationRule @relation(fields: [ruleId], references: [id])
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELED
  NO_SHOW
  RESCHEDULED
}

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PAID
  PARTIAL
  OVERDUE
  CANCELLED
}

enum TreatmentStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
}

enum ReminderType {
  EMAIL
  SMS
  IN_APP
  PHONE
}

enum PracticeRole {
  ADMIN
  DOCTOR
  HYGIENIST
  ASSISTANT
  RECEPTIONIST
  MANAGER
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// Payment and Billing Enums
enum PaymentMethod {
  CASH
  CREDIT_CARD
  DEBIT_CARD
  CHECK
  BANK_TRANSFER
  INSURANCE
  PAYMENT_PLAN
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  CANCELED
}

enum ClaimStatus {
  DRAFT
  SUBMITTED
  PROCESSING
  APPROVED
  DENIED
  PARTIAL
  PAID
  APPEALED
  REJECTED
  UNDER_REVIEW
  RESUBMITTED
}

// Document and Form Enums
enum DocumentType {
  INSURANCE_CARD
  ID_DOCUMENT
  MEDICAL_HISTORY
  CONSENT_FORM
  TREATMENT_PLAN
  XRAY
  PHOTO
  PRESCRIPTION
  REFERRAL
  OTHER
}

enum FormStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  EXPIRED
  CANCELED
}

// Communication Enums
enum TemplateType {
  APPOINTMENT_REMINDER
  APPOINTMENT_CONFIRMATION
  PAYMENT_REMINDER
  FOLLOW_UP
  MARKETING
  EMERGENCY
  RECALL
  BIRTHDAY
  HOLIDAY
}

enum CommunicationChannel {
  SMS
  EMAIL
  PHONE
  IN_APP
  POSTAL_MAIL
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
  BOUNCED
}

// Workflow Enums
enum WorkflowStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELED
  PAUSED
}

enum WorkflowStepType {
  SEND_MESSAGE
  SCHEDULE_APPOINTMENT
  CREATE_TASK
  UPDATE_PATIENT
  WAIT_DELAY
  CONDITIONAL
  WEBHOOK
  EMAIL
  SMS
}

enum StepStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
}

// Analytics and Reporting Enums
enum ReportType {
  FINANCIAL
  PATIENT_DEMOGRAPHICS
  APPOINTMENT_ANALYTICS
  TREATMENT_STATISTICS
  MARKETING_PERFORMANCE
  STAFF_PRODUCTIVITY
  CUSTOM
}

// Social Media Enums
enum SocialPlatform {
  FACEBOOK
  INSTAGRAM
  TWITTER
  LINKEDIN
  YOUTUBE
  TIKTOK
  GOOGLE_BUSINESS
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  FAILED
  ARCHIVED
}

enum CampaignType {
  AWARENESS
  PROMOTION
  EDUCATION
  SEASONAL
  EVENT
  REFERRAL
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  PAUSED
  COMPLETED
  CANCELED
}

// Automation Enums
enum ExecutionStatus {
  RUNNING
  COMPLETED
  FAILED
  CANCELED
}

// Legacy enum for NextAuth compatibility
enum Role {
  ADMIN
  DOCTOR
  STAFF
}

// ============================================================================
// BILLING & INSURANCE ENUMS
// ============================================================================

enum PayerType {
  PRIMARY
  SECONDARY
  TERTIARY
}

enum ClearinghouseType {
  DENTAL
  MEDICAL
  BOTH
}

enum ConnectionStatus {
  CONNECTED
  DISCONNECTED
  ERROR
  TESTING
}

enum InsuranceRelationship {
  SELF
  SPOUSE
  CHILD
  OTHER
}

enum EligibilityStatus {
  PENDING
  VERIFIED
  FAILED
  EXPIRED
}



enum ClaimProcedureStatus {
  PENDING
  APPROVED
  DENIED
  REDUCED
  UNDER_REVIEW
}

enum PaymentType {
  PATIENT_PAYMENT
  INSURANCE_PAYMENT
  ADJUSTMENT
  REFUND
  WRITEOFF
  TRANSFER
}

enum LedgerEntryType {
  CHARGE
  PAYMENT
  ADJUSTMENT
  REFUND
  INSURANCE_PAYMENT
  WRITEOFF
  TRANSFER
}

enum LedgerEntryStatus {
  PENDING
  POSTED
  REVERSED
  VOIDED
}



enum FinancingProvider {
  CARECREDIT
  LENDING_CLUB
  ALPHAEON
  INTERNAL
}

enum FinancingType {
  PROMOTIONAL
  STANDARD
  PAYMENT_PLAN
}

enum FinancingStatus {
  PENDING
  APPROVED
  DECLINED
  ACTIVE
  COMPLETED
  DEFAULTED
}

enum PaymentPlanStatus {
  ACTIVE
  COMPLETED
  DEFAULTED
  CANCELLED
}

enum PaymentScheduleStatus {
  SCHEDULED
  PAID
  LATE
  MISSED
  WAIVED
}

enum CollectionStatus {
  CURRENT
  PAST_DUE
  COLLECTIONS
  BAD_DEBT
  WRITTEN_OFF
}

// Call logging for VoIP integration
model CallLog {
  id              String    @id @default(cuid())
  patientId       String?
  phoneNumber     String
  direction       String    // 'inbound' or 'outbound'
  twilioCallSid   String?   @unique
  status          String    // 'initiated', 'ringing', 'answered', 'completed', 'failed', etc.
  duration        Int?      // Duration in seconds
  recordingUrl    String?   // URL to call recording
  transcription   String?   // Call transcription if available
  notes           String?   // Receptionist notes about the call
  createdAt       DateTime  @default(now())
  endedAt         DateTime?
  createdBy       String?   // User ID of who initiated the call

  patient   Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)
  creator   User?    @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@map("call_logs")
}

// 3rd Party Integration Settings
model IntegrationSettings {
  id          String   @id @default(cuid())
  practiceId  String
  provider    String   // 'twilio', 'ringcentral', 'aws_sns', 'sendgrid', etc.
  service     String   // 'voip', 'sms', 'email', 'translation'
  isActive    Boolean  @default(false)
  config      Json     // Encrypted configuration data
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  practice Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@unique([practiceId, provider, service])
  @@map("integration_settings")
}

// SMS and Communication Logs
model SmsLog {
  id              String    @id @default(cuid())
  patientId       String?
  phoneNumber     String
  message         String
  direction       String    // 'inbound' or 'outbound'
  status          String    // 'sent', 'delivered', 'failed', 'received'
  provider        String    // 'twilio', 'aws_sns', etc.
  providerSid     String?   // Provider's message ID
  cost            Float?    // Cost in cents
  createdAt       DateTime  @default(now())
  deliveredAt     DateTime?
  createdBy       String?   // User ID of who sent the message

  patient   Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)
  creator   User?    @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@map("sms_logs")
}

// Automated Appointment Reminders
model AppointmentReminder {
  id              String    @id @default(cuid())
  appointmentId   String
  reminderType    String    // 'sms', 'email', 'call'
  scheduledFor    DateTime  // When to send the reminder
  status          String    // 'pending', 'sent', 'failed', 'cancelled'
  message         String?   // Custom message content
  attempts        Int       @default(0)
  lastAttempt     DateTime?
  sentAt          DateTime?
  createdAt       DateTime  @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@map("appointment_reminders")
}

model CommunicationSettings {
  id         String   @id @default(cuid())
  practiceId String   @unique
  settings   String   // JSON string containing all communication settings
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  practice Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@map("communication_settings")
}

// ============================================================================
// COMPREHENSIVE BILLING & INSURANCE SYSTEM
// ============================================================================

// Insurance Management
model InsurancePayer {
  id                    String   @id @default(cuid())
  name                  String
  type                  PayerType @default(PRIMARY)
  payerCode             String   @unique
  address               String?
  city                  String?
  state                 String?
  zipCode               String?
  phone                 String?
  email                 String?
  website               String?
  isActive              Boolean  @default(true)
  clearinghouseId       String?
  eligibilityEndpoint   String?
  claimsEndpoint        String?
  remittanceEndpoint    String?
  contractedRates       Json?    // JSON object with coverage rates
  practiceId            String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  practice              Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  clearinghouse         Clearinghouse? @relation(fields: [clearinghouseId], references: [id])
  claims                Claim[]
  eligibilityChecks     EligibilityCheck[]
  patientInsurances     PatientInsurance[]

  @@map("insurance_payers")
}

model Clearinghouse {
  id                    String   @id @default(cuid())
  name                  String
  type                  ClearinghouseType @default(DENTAL)
  apiEndpoint           String
  username              String
  password              String   // Encrypted
  submitterId           String
  receiverId            String
  isActive              Boolean  @default(true)
  supportedTransactions Json     // Array of supported transaction types
  testMode              Boolean  @default(false)
  lastSync              DateTime?
  status                ConnectionStatus @default(DISCONNECTED)
  practiceId            String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  practice              Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  payers                InsurancePayer[]
  claims                Claim[]

  @@map("clearinghouses")
}

model PatientInsurance {
  id                    String   @id @default(cuid())
  patientId             String
  payerId               String
  policyNumber          String
  groupNumber           String?
  subscriberId          String
  subscriberName        String?
  relationship          InsuranceRelationship @default(SELF)
  coverageType          PayerType @default(PRIMARY)
  effectiveDate         DateTime?
  expirationDate        DateTime?
  isActive              Boolean  @default(true)
  eligibilityVerified   Boolean  @default(false)
  lastVerified          DateTime?
  copay                 Float?
  deductible            Float?
  annualMaximum         Float?
  deductibleMet         Float    @default(0)
  benefitsUsed          Float    @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  patient               Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  payer                 InsurancePayer @relation(fields: [payerId], references: [id])
  claims                Claim[]
  eligibilityChecks     EligibilityCheck[]

  @@map("patient_insurances")
}

model EligibilityCheck {
  id                    String   @id @default(cuid())
  patientId             String
  payerId               String
  patientInsuranceId    String?
  serviceDate           DateTime
  status                EligibilityStatus @default(PENDING)
  response              Json?    // Full eligibility response
  benefits              Json?    // Parsed benefits information
  copay                 Float?
  deductible            Float?
  deductibleRemaining   Float?
  annualMaximum         Float?
  benefitsRemaining     Float?
  coveragePercentages   Json?    // Coverage by service category
  limitations           Json?    // Coverage limitations
  exclusions            Json?    // Coverage exclusions
  errorMessage          String?
  requestedAt           DateTime @default(now())
  respondedAt           DateTime?
  practiceId            String

  // Relations
  patient               Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  payer                 InsurancePayer @relation(fields: [payerId], references: [id])
  patientInsurance      PatientInsurance? @relation(fields: [patientInsuranceId], references: [id])
  practice              Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@map("eligibility_checks")
}

// Claims Management
model Claim {
  id                    String   @id @default(cuid())
  claimNumber           String   @unique
  patientId             String
  payerId               String
  patientInsuranceId    String?
  clearinghouseId       String?
  serviceDate           DateTime
  submissionDate        DateTime?
  totalAmount           Float
  paidAmount            Float    @default(0)
  patientResponsibility Float    @default(0)
  status                ClaimStatus @default(DRAFT)
  batchId               String?
  controlNumber         String?
  eobReceived           Boolean  @default(false)
  eobDate               DateTime?
  remittanceAdvice      String?
  denialReason          String?
  denialCodes           Json?    // Array of denial codes
  appealDeadline        DateTime?
  isAppeal              Boolean  @default(false)
  originalClaimId       String?
  practiceId            String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  patient               Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  payer                 InsurancePayer @relation(fields: [payerId], references: [id])
  patientInsurance      PatientInsurance? @relation(fields: [patientInsuranceId], references: [id])
  clearinghouse         Clearinghouse? @relation(fields: [clearinghouseId], references: [id])
  practice              Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  procedures            ClaimProcedure[]
  payments              ClaimPayment[]
  adjustments           ClaimAdjustment[]
  appeals               Claim[] @relation("ClaimAppeals")
  originalClaim         Claim? @relation("ClaimAppeals", fields: [originalClaimId], references: [id])

  @@map("claims")
}

model ClaimProcedure {
  id                    String   @id @default(cuid())
  claimId               String
  procedureCode         String
  description           String
  tooth                 String?
  surface               String?
  quantity              Int      @default(1)
  chargedAmount         Float
  allowedAmount         Float    @default(0)
  paidAmount            Float    @default(0)
  deductible            Float    @default(0)
  copay                 Float    @default(0)
  coinsurance           Float    @default(0)
  status                ClaimProcedureStatus @default(PENDING)
  denialCodes           Json?    // Array of denial codes
  remarkCodes           Json?    // Array of remark codes
  lineNumber            Int?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  claim                 Claim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@map("claim_procedures")
}

model ClaimPayment {
  id                    String   @id @default(cuid())
  claimId               String
  paymentDate           DateTime
  amount                Float
  checkNumber           String?
  eobNumber             String?
  paymentMethod         String?
  transactionId         String?
  adjustmentAmount      Float    @default(0)
  interestAmount        Float    @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  claim                 Claim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@map("claim_payments")
}

model ClaimAdjustment {
  id                    String   @id @default(cuid())
  claimId               String
  adjustmentCode        String
  adjustmentReason      String?
  amount                Float
  adjustmentDate        DateTime
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  claim                 Claim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@map("claim_adjustments")
}

// Billing and Ledger Management
model LedgerEntry {
  id                    String   @id @default(cuid())
  patientId             String
  practiceId            String
  transactionDate       DateTime
  type                  LedgerEntryType
  description           String
  procedureCode         String?
  amount                Float
  balance               Float
  status                LedgerEntryStatus @default(PENDING)
  invoiceId             String?
  claimId               String?
  paymentId             String?
  notes                 String?
  createdBy             String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  patient               Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  practice              Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@map("ledger_entries")
}

model AccountsReceivable {
  id                    String   @id @default(cuid())
  patientId             String
  practiceId            String
  totalBalance          Float
  insuranceBalance      Float    @default(0)
  patientBalance        Float    @default(0)
  currentBalance        Float    @default(0)
  days30Balance         Float    @default(0)
  days60Balance         Float    @default(0)
  days90Balance         Float    @default(0)
  days120PlusBalance    Float    @default(0)
  lastPaymentDate       DateTime?
  lastPaymentAmount     Float?
  collectionStatus      CollectionStatus @default(CURRENT)
  paymentPlan           Boolean  @default(false)
  lastStatementDate     DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  patient               Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  practice              Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@unique([patientId, practiceId])
  @@map("accounts_receivable")
}

model PatientInvoice {
  id                    String   @id @default(cuid())
  invoiceNumber         String   @unique
  patientId             String
  practiceId            String
  serviceDate           DateTime
  dueDate               DateTime
  totalAmount           Float
  paidAmount            Float    @default(0)
  remainingBalance      Float
  status                InvoiceStatus @default(DRAFT)
  paymentLink           String?
  sentDate              DateTime?
  viewedDate            DateTime?
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  patient               Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  practice              Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  procedures            InvoiceProcedure[]
  payments              InvoicePayment[]

  @@map("patient_invoices")
}

model InvoiceProcedure {
  id                    String   @id @default(cuid())
  invoiceId             String
  procedureCode         String
  description           String
  tooth                 String?
  quantity              Int      @default(1)
  unitPrice             Float
  totalPrice            Float
  createdAt             DateTime @default(now())

  // Relations
  invoice               PatientInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_procedures")
}

model InvoicePayment {
  id                    String   @id @default(cuid())
  invoiceId             String
  amount                Float
  paymentDate           DateTime
  paymentMethod         String
  transactionId         String?
  notes                 String?
  createdAt             DateTime @default(now())

  // Relations
  invoice               PatientInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_payments")
}

// Patient Financing System
model FinancingOption {
  id                    String   @id @default(cuid())
  practiceId            String
  provider              FinancingProvider
  name                  String
  type                  FinancingType
  minAmount             Float
  maxAmount             Float
  termMonths            Int
  interestRate          Float
  promotionalRate       Float?
  promotionalMonths     Int?
  isActive              Boolean  @default(true)
  applicationUrl        String?
  apiEndpoint           String?
  apiKey                String?  // Encrypted
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  practice              Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  applications          PatientFinancing[]

  @@map("financing_options")
}

model PatientFinancing {
  id                    String   @id @default(cuid())
  patientId             String
  practiceId            String
  financingOptionId     String
  applicationId         String?
  amount                Float
  termMonths            Int
  interestRate          Float
  monthlyPayment        Float
  status                FinancingStatus @default(PENDING)
  approvedAmount        Float?
  approvedDate          DateTime?
  declinedReason        String?
  firstPaymentDate      DateTime?
  lastPaymentDate       DateTime?
  remainingBalance      Float?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  patient               Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  practice              Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  financingOption       FinancingOption @relation(fields: [financingOptionId], references: [id])
  payments              FinancingPayment[]

  @@map("patient_financing")
}

model FinancingPayment {
  id                    String   @id @default(cuid())
  patientFinancingId    String
  amount                Float
  paymentDate           DateTime
  dueDate               DateTime
  status                PaymentScheduleStatus @default(SCHEDULED)
  transactionId         String?
  notes                 String?
  createdAt             DateTime @default(now())

  // Relations
  patientFinancing      PatientFinancing @relation(fields: [patientFinancingId], references: [id], onDelete: Cascade)

  @@map("financing_payments")
}

model PaymentPlan {
  id                    String   @id @default(cuid())
  patientId             String
  practiceId            String
  totalAmount           Float
  downPayment           Float    @default(0)
  monthlyPayment        Float
  numberOfPayments      Int
  interestRate          Float    @default(0)
  startDate             DateTime
  status                PaymentPlanStatus @default(ACTIVE)
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  patient               Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  practice              Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  schedules             PaymentSchedule[]

  @@map("payment_plans")
}

model PaymentSchedule {
  id                    String   @id @default(cuid())
  paymentPlanId         String
  paymentNumber         Int
  dueDate               DateTime
  amount                Float
  status                PaymentScheduleStatus @default(SCHEDULED)
  paidDate              DateTime?
  paidAmount            Float?
  transactionId         String?
  notes                 String?
  createdAt             DateTime @default(now())

  // Relations
  paymentPlan           PaymentPlan @relation(fields: [paymentPlanId], references: [id], onDelete: Cascade)

  @@map("payment_schedules")
}
