{
	"name": "coredentalapp",
	"version": "0.1.5",
	"private": true,
	"scripts": {
		"build": "next build",
		"start": "next start",
		"dev": "next dev",
		"preview": "npm run build && npm run start",
		"db:generate": "prisma generate",
		"db:migrate": "prisma migrate deploy",
		"db:push": "npx prisma db push --accept-data-loss",
		"db:studio": "prisma studio",
		"db:seed": "npm run db:push && npm run seed",
		"typecheck": "tsc --noEmit",
		"lint": "biome check src",
		"lint:fix": "biome check --apply src",
		"production:build": "NODE_ENV=production npm run build",
		"production:start": "NODE_ENV=production npm run start",
		"cpanel:install": "npm install --omit=dev --legacy-peer-deps && npm run db:generate && npm run build",
		"cpanel:migrate": "npm run db:migrate",
		"cpanel:deploy": "npm run cpanel:install && npm run cpanel:migrate",
		"health:check": "tsx scripts/health-check.ts",
		"check-env": "node scripts/check-env.js",
		"db:reset": "npx prisma migrate reset --force && npm run seed",
		"test": "playwright test",
		"test:ui": "playwright test --ui",
		"test:headed": "playwright test --headed",
		"test:debug": "playwright test --debug",
		"test:report": "playwright show-report",
		"test:install": "playwright install",
		"health-check": "tsx scripts/health-check.ts"
	},
