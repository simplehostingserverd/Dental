# npm configuration for cPanel deployment
# Resolves peer dependency conflicts common in Next.js applications

legacy-peer-deps=true
fund=false
audit=false
strict-peer-deps=false

# Production optimizations
production=true
optional=false

# Registry settings
registry=https://registry.npmjs.org/

# Cache settings for faster installs
cache-min=86400

# Force resolution of peer dependency conflicts
force=false
prefer-offline=false
