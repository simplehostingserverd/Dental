# npm configuration for cPanel deployment
# Resolves peer dependency conflicts common in Next.js applications

legacy-peer-deps=true
fund=false
audit=false
strict-peer-deps=false
auto-install-peers=true

# Production optimizations
production=true
optional=false

# Registry settings
registry=https://registry.npmjs.org/

# Cache settings for faster installs
cache-min=86400

# Force resolution of peer dependency conflicts
force=false
prefer-offline=false

# Additional conflict resolution
save-exact=false
package-lock=true

# Engine compatibility
engine-strict=false

# Override resolution strategy
prefer-dedupe=true
